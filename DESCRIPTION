Package: strollur
Type: Package
Title: Store and Transfer Data Associated with Amplicon Sequence Analysis
Version: 0.1.0
Date: 2026-05-19
Authors@R: c(
    person("Sarah", "Westcott", role = c("aut", "cre"),
